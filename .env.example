# Copy this file to .env and fill in the values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API)

# Your Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# The public "anon" API key (safe for the browser; real security is enforced
# by Row Level Security policies in the database)
VITE_SUPABASE_ANON_KEY=

# --- Sentry (optional error monitoring) -------------------------------------
# Leave blank to disable Sentry entirely (the app runs unchanged with no DSN).
# Get the DSN from Sentry -> Project -> Settings -> Client Keys (DSN).
VITE_SENTRY_DSN=

# Environment label shown in Sentry (defaults to Vite's mode, e.g. production).
VITE_SENTRY_ENVIRONMENT=

# Release identifier for source-map matching (e.g. a git SHA). Optional.
VITE_SENTRY_RELEASE=

# Fraction of transactions traced for performance (0 to 1). Defaults to 0.1.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Set to "true" to enable masked Session Replay on errors. Off by default
# because this is a system with student PII.
VITE_SENTRY_ENABLE_REPLAY=

# --- Sentry build-time (source-map upload; set these in Vercel, not .env) ----
# When SENTRY_AUTH_TOKEN is present at build time, vite uploads hidden source
# maps to Sentry and deletes them from the build output. Leave unset locally.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# --- Cloudflare Turnstile (NAT submission/login CAPTCHA) ---------------------
# Site key is public (rendered in the browser). Configure it together with the
# server secret; leaving both blank disables Turnstile for local development.
VITE_TURNSTILE_SITE_KEY=

# Edge Functions (Supabase secrets, not this file):
#   supabase secrets set SENTRY_DSN="https://...ingest.sentry.io/..."
#   supabase secrets set SENTRY_ENVIRONMENT="production"
#   supabase secrets set TURNSTILE_SECRET_KEY="0x..." (enables NAT CAPTCHA)
