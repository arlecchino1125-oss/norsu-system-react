{
  "name": "norsu-system-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:student": "vite --config apps/student/vite.config.js",
    "build": "vite build",
    "build:student": "vite build --config apps/student/vite.config.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:student": "vite preview --config apps/student/vite.config.js",
    "typecheck": "tsc --noEmit",
    "typecheck:student": "tsc -p apps/student/tsconfig.json --noEmit",
    "mobile:student:sync": "npm run build:student && npm --prefix apps/student run cap:sync",
    "mobile:student:add:android": "npm --prefix apps/student run cap:add:android",
    "mobile:student:add:ios": "npm --prefix apps/student run cap:add:ios",
    "mobile:student:open:android": "npm --prefix apps/student run cap:open:android",
    "mobile:student:open:ios": "npm --prefix apps/student run cap:open:ios",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sanitize:storage": "node scripts/empty-production-storage.mjs",
    "sanitize:storage:dry-run": "node scripts/empty-production-storage.mjs --dry-run",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@supabase/supabase-js": "^2.95.3",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "msw": "^2.7.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.8"
  }
}
